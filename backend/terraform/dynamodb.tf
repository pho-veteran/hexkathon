locals {
  table_prefix = "study-buddy-${var.group_id}"
}

resource "aws_dynamodb_table" "documents" {
  name         = "${local.table_prefix}-documents"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "userId"
  range_key    = "sk"

  attribute {
    name = "userId"
    type = "S"
  }

  attribute {
    name = "sk"
    type = "S"
  }

  point_in_time_recovery {
    enabled = true
  }

  server_side_encryption {
    enabled = true
  }
}

